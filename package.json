{
  "name": "@noclaps/highlight",
  "version": "0.3.2",
  "devDependencies": {
    "@napi-rs/cli": "^3.0.0-alpha.65",
    "@types/bun": "^1.1.14"
  },
  "scripts": {
    "build": "napi build --platform --esm --release --strip --js ./dist/index.js --dts ./dist/index.d.ts -o ./dist",
    "bump": "bunx changelogen --bump && bun bump-version.ts"
  },
  "napi": {
    "binaryName": "highlight",
    "targets": [
      "wasm32-wasip1"
    ]
  },
  "type": "module",
  "exports": "./index.ts",
  "files": [
    "dist",
    "index.ts",
    "LICENSE",
    "README.md",
    "package.json"
  ]
}
