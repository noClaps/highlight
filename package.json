{
  "name": "@noclaps/highlight",
  "version": "0.3.2",
  "devDependencies": {
    "@napi-rs/cli": "^3.0.0-alpha.65",
    "@napi-rs/wasm-runtime": "^0.2.6",
    "@types/bun": "^1.1.14"
  },
  "exports": "./main.ts",
  "files": [
    "main.ts",
    "LICENSE",
    "README.md",
    "package.json"
  ],
  "napi": {
    "binaryName": "highlight",
    "targets": [
      "wasm32-wasip1"
    ]
  },
  "scripts": {
    "build": "napi build --platform --esm --release --strip -o ./dist",
    "bump": "bunx changelogen --bump && bun bump-version.ts"
  },
  "type": "module"
}
